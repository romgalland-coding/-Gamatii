<%= turbo_stream.append "post-comments-#{@post.id}" do %>
  <%= render "comments/comment", comment: @comment, post: @post %>
<% end %>
<%= turbo_stream.update "post-comment-form-#{@post.id}" do %>
  <%= render "comments/form", post: @post %>
<% end %>
<%= turbo_stream.update "post-comment-count-#{@post.id}" do %>
  <%= @post.comments.count %>
<% end %>
