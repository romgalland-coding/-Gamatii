<div class="discover">
  <header class="discover__header">
    <h1 class="discover__title">Discover</h1>
    <p class="discover__subtitle pt-3">Let <strong>Matia</strong> find your next game.</p>
    <p class="discover__subtitle pt-3">Not sure what to play next? Chat with our AI game advisor and tell it what you're in the mood for.</p>
  </header>

  <%= button_to chats_path, method: :post, class: "btn btn-primary discover__new-chat" do %>
    <i class="fa-solid fa-plus me-2"></i>Create a new chat
  <% end %>

  <section class="discover__section" data-controller="list-search">
    <h2 class="discover__section-title">Search trough lists</h2>
    <div class="discover__search-bar">
      <i class="fa-solid fa-magnifying-glass discover__search-icon"></i>
      <input
        type="text"
        class="discover__search-input"
        placeholder="Search by list name…"
        autocomplete="off"
        data-list-search-target="input"
        data-action="input->list-search#search"
      >
    </div>
    <div id="list_search_results" data-list-search-target="results" class="discover__list-results"></div>
    <div id="list_search_more"></div>
  </section>

  <% if @top_lists_this_week.any? %>
    <section class="discover__section">
      <h2 class="discover__section-title">Top 3 of the week</h2>
      <div class="discover__top-week">
        <% @top_lists_this_week.each_with_index do |list, i| %>
          <%= render "lists/discover_list_card", list: list, rank: i + 1 %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>

<%= render "shared/navbar", active: :discover %>
