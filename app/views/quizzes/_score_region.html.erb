<%# The score screen + leaderboard. Wrapped in a stable id so a correct-guess
    turbo_stream can re-render it. `auto_open` opens the overlay on connect
    (true once all guesses are used). %>
<%
  share_text = "gamatii daily quiz #{Date.current.strftime('%-d %b %Y')}\n" \
               "My score: #{score}\n" \
               "#{root_url}"
  avatars = { "PixelKnight" => "🦊", "NeonByte" => "🌿", "VortexCaster" => "📖" }
  auto = local_assigns.fetch(:auto_open, guesses_remaining <= 0)
  round_ended = local_assigns.fetch(:round_ended, false)
  global  = leaderboard[:global]
  follows = leaderboard[:follows]
  follows_anyone = current_user.following.exists?
%>
<div id="quiz_score_region">
  <div data-controller="quiz-score leaderboard-toggle"
       data-quiz-score-auto-value="<%= auto %>"
       data-quiz-score-share-text-value="<%= share_text %>">

    <% if guesses_remaining <= 0 %>
      <button type="button" class="quiz-results-trigger"
              data-action="quiz-score#open">View results</button>
    <% end %>

    <div class="quiz-score-overlay" data-quiz-score-target="overlay">
      <div class="quiz-score-card">
        <div class="quiz-score-card__head">
          <p class="quiz-score-card__label">YOUR SCORE</p>
          <h2 class="quiz-score-card__value"><%= score %></h2>
          <p class="quiz-score-card__meta">
            <%= found %>/5 found ·
            <%# Rank depends on the active view, so render both and toggle them. %>
            <span data-leaderboard-toggle-target="meta" data-view="global">ranked #<%= global[:my_rank] %> of <%= global[:total_players] %></span>
            <span data-leaderboard-toggle-target="meta" data-view="follows" hidden>ranked #<%= follows[:my_rank] %> of <%= follows[:total_players] %></span>
          </p>
          <button type="button" class="quiz-score-card__close"
                  data-action="quiz-score#close" aria-label="Close">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>

        <div class="quiz-score-card__body">
          <div class="quiz-leaderboard-toggle" role="tablist">
            <button type="button" class="quiz-leaderboard-toggle__btn quiz-leaderboard-toggle__btn--active"
                    data-leaderboard-toggle-target="tab" data-view="global"
                    data-action="leaderboard-toggle#switch">Global</button>
            <button type="button" class="quiz-leaderboard-toggle__btn"
                    data-leaderboard-toggle-target="tab" data-view="follows"
                    data-action="leaderboard-toggle#switch">Follows</button>
          </div>

          <%# Global view %>
          <ul class="quiz-leaderboard" data-leaderboard-toggle-target="view" data-view="global">
            <%= render partial: "quizzes/leaderboard_row", collection: global[:rows], as: :row, locals: { avatars: avatars } %>
          </ul>

          <%# Follows view — empty state when the user follows no one. %>
          <div data-leaderboard-toggle-target="view" data-view="follows" hidden>
            <% if follows_anyone %>
              <ul class="quiz-leaderboard">
                <%= render partial: "quizzes/leaderboard_row", collection: follows[:rows], as: :row, locals: { avatars: avatars } %>
              </ul>
            <% else %>
              <p class="quiz-leaderboard__empty">Follow other people and compare your score with them!</p>
            <% end %>
          </div>

          <button type="button" class="quiz-score-share"
                  data-action="quiz-score#share">
            <i class="fa-solid fa-share-nodes"></i> Share score
          </button>

          <% if round_ended %>
            <%# Time's up: move on to the new day's quiz (drops the ?ended pin). %>
            <%= link_to "Next quiz →", daily_quizzes_path, class: "quiz-next-quiz" %>
          <% end %>
        </div>
      </div><%# /quiz-score-card %>
    </div><%# /quiz-score-overlay %>
  </div><%# /quiz-score controller %>
</div>
