<div class="quiz-page">

  <div class="quiz-header">
    <div>
      <h1 class="quiz-title"><i class="fa-solid fa-trophy"></i> Daily Quiz</h1>
      <p class="quiz-subtitle">Guess today's list, pick for tomorrow's.</p>
    </div>
    <div class="quiz-header__aside" data-controller="quiz-howto">
      <button type="button" class="quiz-howto-btn" data-action="quiz-howto#open">
        <i class="fa-regular fa-circle-question"></i> How to play
      </button>
      <%= render "quizzes/howto_modal" %>
    </div>
  </div>

  <% pick_tab = params[:tab] == "pick" %>
  <div class="quiz-tabs">
    <%= link_to daily_quizzes_path, class: "quiz-tab #{'quiz-tab--active' unless pick_tab}" do %>
      Today's Quiz
    <% end %>
    <%= link_to daily_quizzes_path(tab: "pick"), class: "quiz-tab #{'quiz-tab--active' if pick_tab}" do %>
      Pick for Tomorrow
    <% end %>
  </div>

  <% unless pick_tab %>

    <%# ---- TODAY'S QUIZ (guess) TAB — now the default ---- %>

    <div class="quiz-prompt quiz-prompt--blue">
      <div class="quiz-prompt__label-row">
        <p class="quiz-prompt__label">TODAY'S QUIZ</p>
        <%= render "quizzes/timer", ended_quiz_id: @yesterday_quiz.id %>
      </div>
      <h2 class="quiz-prompt__title"><%= @yesterday_quiz.name %></h2>
      <p class="quiz-prompt__desc">Guess what the gamatii community selected</p>
      <% if current_user %>
        <%= render "quizzes/score_line", score: @score, guesses_remaining: @guesses_remaining %>
      <% end %>
    </div>

    <% if current_user %>
      <%= render "quizzes/input_region", quiz: @yesterday_quiz, guesses_remaining: @guesses_remaining %>
    <% end %>

    <ol class="quiz-answers">
      <% reveal_all = current_user && @guesses_remaining <= 0 %>
      <% @yesterday_answers.each_with_index do |game, i| %>
        <%= render "quizzes/answer_row", game: game, index: i,
              guessed: current_user && @guessed_titles.include?(normalize_title(game.title)),
              reveal_all: reveal_all %>
      <% end %>
    </ol>

    <%# ---- YOUR PICKS FROM YESTERDAY ---- a reference list of what this user
        picked when this quiz was "today", so they can re-enter them as guesses.
        Only appears if they made at least one pick. %>
    <% if current_user && @my_yesterday_picks.any? %>
      <div id="quiz_yesterday_picks" class="quiz-yesterday-picks">
        <p class="quiz-yesterday-picks__label">YOUR PICKS</p>
        <ul class="quiz-yesterday-picks__list">
          <% @my_yesterday_picks.each do |qg| %>
            <%= render "quizzes/yesterday_pick", qg: qg, quiz: @yesterday_quiz,
                  disabled: @guesses_remaining <= 0 %>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# ---- SCORE SCREEN ---- shown automatically once all 5 guesses are used,
        dismissable via X, re-openable via "View results". %>
    <% if current_user %>
      <%= render "quizzes/score_region",
            score: @score, guesses_remaining: @guesses_remaining,
            found: @found, leaderboard: @leaderboard, round_ended: @round_ended %>
    <% end %>

  <% else %>

    <%# ---- TODAY TAB ---- %>

    <div class="quiz-prompt quiz-prompt--yellow">
      <div class="quiz-prompt__label-row">
        <p class="quiz-prompt__label">TOMORROW'S LIST</p>
        <%= render "quizzes/timer" %>
      </div>
      <h2 class="quiz-prompt__title"><%= @today_quiz.name %></h2>
      <p class="quiz-prompt__desc">Add up to 5 games. Submissions close at midnight CET.</p>
    </div>

    <% if current_user %>
      <div class="quiz-input-row"
           data-controller="quiz-autocomplete"
           data-quiz-autocomplete-url-value="<%= autocomplete_games_quiz_path(@today_quiz) %>">
        <%= text_field_tag :quiz_query,
              nil,
              placeholder: "Search a game to pick…",
              class: "quiz-input",
              autocomplete: "off",
              disabled: @my_submissions.count >= 5,
              data: { action: "input->quiz-autocomplete#search" } %>
        <div id="quiz_autocomplete_results" class="quiz-autocomplete-results"></div>
      </div>

      <p class="quiz-picks-label">YOUR PICKS · <%= @my_submissions.count %>/5</p>

      <% if @my_submissions.any? %>
        <ul class="quiz-picks">
          <% @my_submissions.each do |qg| %>
            <li class="quiz-pick-row">
              <span><%= qg.game.title %></span>
              <%= link_to quiz_game_path(qg),
                    class: "quiz-pick-row__remove",
                    data: { turbo_method: :delete } do %>
                <i class="fa-solid fa-xmark"></i>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="quiz-picks-empty">Add games to get started.</div>
      <% end %>

    <% else %>
      <div class="quiz-picks-empty">
        <%= link_to "Sign in", new_user_session_path %> to submit your picks.
      </div>
    <% end %>

  <% end %>

</div>

<%= render "shared/navbar" %>
