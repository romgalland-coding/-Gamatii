<% revealed_i = @yesterday_answers.index { |a| normalize_title(a.title) == normalize_title(@game.title) } %>
<% round_over = @guesses_remaining <= 0 %>

<%# If this guess came from clicking a yesterday-pick, remove that row from the
    reference list (it's been "used", right or wrong). %>
<% if @from_pick_id %>
  <%= turbo_stream.remove "yesterday_pick_#{@from_pick_id}" %>
<% end %>

<% if @correct %>
  <%# Reveal the matched row with a green fill-sweep. %>
  <%= turbo_stream.replace "answer_row_#{revealed_i}" do %>
    <%= render "quizzes/answer_row", game: @yesterday_answers[revealed_i],
          index: revealed_i, guessed: true, just_revealed: true %>
  <% end %>

  <%# Score line counts up from the pre-guess total. %>
  <%= turbo_stream.replace "quiz_score_line" do %>
    <%= render "quizzes/score_line", score: @score,
          guesses_remaining: @guesses_remaining, animate_from: @previous_score %>
  <% end %>

  <%= turbo_stream.update "quiz_guess_feedback", "" %>

<% else %>
  <%# Wrong guess: shake the search bar and show the red message. %>
  <%= turbo_stream.replace "quiz_guess_feedback" do %>
    <div id="quiz_guess_feedback"
         class="quiz-guess-feedback"
         data-controller="quiz-shake"
         data-quiz-shake-target-selector-value=".quiz-input">
      <%= @game.title %> is not on the list!
    </div>
  <% end %>

  <%# A wrong guess still costs a slot, so refresh the score/LEFT cards (no
      count-up — a miss scores 0). %>
  <%= turbo_stream.replace "quiz_score_line" do %>
    <%= render "quizzes/score_line", score: @score, guesses_remaining: @guesses_remaining %>
  <% end %>
<% end %>

<% if round_over %>
  <%# Round over: reveal every answer (correct→green, missed→red). Skip the row
      the user just matched on a correct guess so its fill-sweep isn't clobbered. %>
  <% @yesterday_answers.each_with_index do |game, i| %>
    <% next if @correct && i == revealed_i %>
    <%= turbo_stream.replace "answer_row_#{i}" do %>
      <%= render "quizzes/answer_row", game: game, index: i,
            guessed: @guessed_titles.include?(normalize_title(game.title)), reveal_all: true %>
    <% end %>
  <% end %>

  <%# Disable the input and open the score screen. %>
  <%= turbo_stream.replace "quiz_input_region" do %>
    <%= render "quizzes/input_region", quiz: @yesterday_quiz, guesses_remaining: @guesses_remaining %>
  <% end %>
  <%= turbo_stream.replace "quiz_score_region" do %>
    <%= render "quizzes/score_region",
          score: @score, guesses_remaining: @guesses_remaining,
          found: @found, leaderboard: @leaderboard, auto_open: true %>
  <% end %>
<% end %>
