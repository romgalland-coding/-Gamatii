<div class="lists-page"
     data-controller="discover"
     data-discover-list-id-value="<%= @list.id %>"
     data-discover-initial-mode-value="<%= params[:query].present? ? 'grid' : 'swipe' %>">

  <div class="game-show__header">
    <%= link_to discover_path, class: "game-show__back" do %>
      <i class="fa-solid fa-arrow-left"></i> Back
    <% end %>
    <h1 class="lists-title mb-0"><%= @list.name %></h1>
  </div>

  <div class="d-flex gap-2">
    <button class="btn btn-warning flex-fill" data-action="click->discover#showSwipe" data-discover-target="btnSwipe">Swipe</button>
    <button class="btn btn-outline-primary flex-fill" data-action="click->discover#showGrid" data-discover-target="btnGrid">Search</button>
  </div>

  <%# SWIPE MODE %>
  <div data-discover-target="swipeView" class="discover-swipe-deck">
    <% @games.first(10).each_with_index do |game, index| %>
      <div class="card position-absolute start-50 translate-middle-x"
           data-discover-target="card"
           data-game-id="<%= game.id %>"
           style="width: 100%; max-width: 340px; z-index: <%= 100 - index %>; top: <%= index * 5 %>px; transition: all 0.3s ease;">
        <div class="discover-swipe-card__cover" style="background-image: url('<%= game.cover_img %>')"></div>
        <div class="p-3 pb-2">
          <% if game.genre.present? %>
            <span class="chip chip-green d-inline-block mb-2"><%= game.genre %></span>
          <% end %>
          <h3 class="fw-bold fs-5 mb-1"><%= game.title %></h3>
          <p class="text-muted small mb-0 lh-base"><%= truncate(game.description.to_s, length: 120) %></p>
        </div>
        <div class="d-flex justify-content-center gap-4 pb-4 pt-2">
          <button class="btn btn-danger discover-swipe-btn" data-action="click->discover#dislike">
            <i class="fa-solid fa-xmark fs-5"></i>
          </button>
          <button class="btn btn-success discover-swipe-btn" data-action="click->discover#like">
            <i class="fa-solid fa-check fs-5"></i>
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <%# GRID/SEARCH MODE %>
  <div data-discover-target="gridView" class="d-none">
    <%= form_with url: discover_list_path(@list), method: :get do |f| %>
      <%= f.text_field :query, value: params[:query], placeholder: "Type the name of the game you're looking for", class: "form-control mb-3" %>
    <% end %>

    <div class="row row-cols-2 g-3">
      <% @games.each do |game| %>
        <div class="col">
          <div class="card h-100">
            <div class="discover-grid-card__cover" style="background-image: url('<%= game.cover_img %>')">
              <%= form_with url: list_list_games_path(@list), method: :post do |f| %>
                <%= hidden_field_tag :game_id, game.id %>
                <button type="submit" class="discover-grid-card__add-btn">+</button>
              <% end %>
            </div>
            <div class="p-2">
              <p class="fw-bold small mb-0 text-truncate"><%= game.title %></p>
              <p class="text-muted mb-0" style="font-size: 0.75rem;"><%= game.genre %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

</div>

<%= render "shared/navbar" %>
