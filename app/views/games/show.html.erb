<div class="game-show" data-controller="add-to-list">

  <div class="game-show__header">
    <%= link_to :back, class: "game-show__back" do %>
      <i class="fa-solid fa-arrow-left"></i> Back
    <% end %>
    <div class="game-show__badges">
      <% if @user_lists.present? %>
        <% @user_lists.first(2).each do |list| %>
          <span class="game-show__list-badge">
            <i class="fa-solid fa-heart"></i>
            <%= list.list_type.in?(%w[wishlist played]) ? list.list_type.capitalize : list.name %>
          </span>
        <% end %>
      <% end %>
    </div>
  </div>

  <h1 class="game-show__title"><%= @game.title %></h1>
  <%# <p class="game-show__genre"><%= @game.genre %>

  <% if @game.platforms.present? %>
    <div class="game-show__tags">
      <% @game.platforms.map { |p| short_platform_label(p) }.uniq.each do |label| %>
        <span class="game-show__platform-tag"><%=label%></span>
      <% end %>
    </div>
  <% end %>

  <div class="game-show__cover" <%= lazy_bg(@game.cover_img) %>>
    <% if @game.rating.present? %>
      <span class="game-show__metascore"><%= @game.rating %></span>
    <% end %>
  </div>

  <% shots = @game.screenshots.presence || [@game.in_game_img].compact %>
  <div class="game-show__thumbnails"
       data-controller="lightbox"
       data-lightbox-images-value="<%= shots.to_json %>">
    <% shots.each_with_index do |url, i| %>
      <div class="game-show__thumb game-show__thumb--clickable"
           <%= lazy_bg(rawg_thumb(url)) %>
           data-action="click->lightbox#open"
           data-lightbox-index-param="<%= i %>"></div>
    <% end %>
      <div class="lightbox" data-lightbox-target="overlay" data-action="keydown@window->lightbox#handleKey">
      <div class="lightbox__backdrop" data-action="click->lightbox#close"></div>
      <div class="lightbox__box">
        <button class="lightbox__close" data-action="click->lightbox#close">✕</button>
        <div class="lightbox__image" data-lightbox-target="image"></div>
        <% if shots.size > 1 %>
          <button class="lightbox__nav lightbox__nav--prev" data-action="click->lightbox#prev">‹</button>
          <button class="lightbox__nav lightbox__nav--next" data-action="click->lightbox#next">›</button>
        <% end %>
        <div class="lightbox__counter" data-lightbox-target="counter"></div>
      </div>
    </div>
  </div>


  <h2 class="game-show__section-title">Description</h2>
  <% desc = @game.description.to_s %>
  <% truncated = desc.length > 220 %>
  <div class="game-show__desc-box" <% if truncated %>data-controller="expand"<% end %>>
    <% if truncated %>
      <span data-expand-target="short"><%= desc[0..219].rstrip %>…</span>
      <span data-expand-target="full" class="d-none"><%= desc %></span>
      <button class="game-show__read-more" data-action="click->expand#toggle">
        <span data-expand-target="btn">Read more</span>
      </button>
    <% else %>
      <%= desc %>
    <% end %>
  </div>

  <div class="game-show__info">
    <div class="game-show__info-badge">
      <div class="game-show__info-label">Studio</div>
      <%= @game.developer || "TBD" %>
    </div>
    <div class="game-show__info-badge" style="flex: 0 0 auto; min-width: 4.5rem;">
      <div class="game-show__info-label">Released</div>
      <%= @game.release_date&.year || "TBD" %>
    </div>
    <div class="game-show__info-badge" style="flex: 2;">
      <div class="game-show__info-label">Genre</div>
      <%= @game.genre.presence || "N/A" %>
    </div>
  </div>

  <% if @game.store_links.present? %>
    <h2 class="game-show__section-title">Buy</h2>
    <% store_rows = @game.store_links.size > 6 ? @game.store_links.each_slice((@game.store_links.size / 2.0).ceil).to_a : [@game.store_links] %>
    <div class="game-show__stores-wrap">
      <% store_rows.each do |row| %>
        <div class="game-show__stores">
          <% row.each do |store| %>
            <%= link_to store["url"], target: "_blank", rel: "noopener noreferrer",
                class: "game-show__store-btn" do %>
              <i class="<%= store_icon(store["slug"]) %>"></i>
              <%= store["name"] %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if current_user %>
    <%= link_to "+ Add to a list", "#",
        class: "btn btn-primary w-100 game-show__cta",
        data: { action: "click->add-to-list#open" } %>
    <%= render "add_to_list_panel", game: @game, lists: @all_user_lists, game_list_games: @game_list_games %>
  <% end %>

</div>

<%= render "shared/navbar" %>
