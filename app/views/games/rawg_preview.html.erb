<%= turbo_frame_tag "game_preview_#{@rawg_id}" do %>
  <% if @game["background_image"].present? %>
    <div class="game-show__cover mb-3" <%= lazy_bg(rawg_thumb(@game["background_image"], 600)) %>></div>
  <% end %>

  <p class="game-show__genre"><%= @game["genres"]&.map { |g| g["name"] }&.join(", ") %></p>
  <h1 class="game-show__title mb-2"><%= @game["name"] %></h1>

  <% if @game["platforms"].present? %>
    <div class="game-show__tags mb-3">
      <% @game["platforms"].each do |p| %>
        <span class="game-show__platform-tag"><%= p.dig("platform", "name") %></span>
      <% end %>
    </div>
  <% end %>

  <h2 class="game-show__section-title">Description</h2>
  <% desc = @game["description_raw"].to_s.presence || "No description available." %>
  <% truncated = desc.length > 220 %>
  <div class="game-show__desc-box" <% if truncated %>data-controller="expand"<% end %>>
    <% if truncated %>
      <span data-expand-target="short"><%= desc[0..219].rstrip %>…</span>
      <span data-expand-target="full" class="d-none"><%= desc %></span>
      <button class="game-show__read-more" data-action="click->expand#toggle">
        <span data-expand-target="btn">Read more</span>
      </button>
    <% else %>
      <%= desc %>
    <% end %>
  </div>

  <div class="game-show__info mt-3">
    <div class="game-show__info-badge">
      <div class="game-show__info-label">Studio</div>
      <%= @game["developers"]&.map { |d| d["name"] }&.join(", ").presence || "TBD" %>
    </div>
    <div class="game-show__info-badge">
      <div class="game-show__info-label">Released</div>
      <%= @game["released"]&.first(4) || "TBD" %>
    </div>
    <div class="game-show__info-badge">
      <div class="game-show__info-label">Rating</div>
      <%= @game["metacritic"] || "N/A" %>
    </div>
  </div>
<% end %>
