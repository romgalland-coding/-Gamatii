<%
  platforms = list_games.flat_map { |lg| Array(lg.game.platforms) }.uniq.compact.sort
  genres    = list_games.map { |lg| lg.game.genre }.compact.uniq.sort
  studios   = list_games.map { |lg| lg.game.developer }.compact.uniq.sort
  years     = list_games.map { |lg| lg.game.release_date&.year }.compact.uniq
  min_year  = years.min || 2000
  max_year  = Date.current.year
%>

<div class="list-filter-panel" data-list-filter-target="panel">
  <div class="list-filter-panel__inner">

    <div class="list-filter-panel__header">
      <span class="list-filter-panel__title">Filter games</span>
      <button class="list-filter-panel__close"
              data-action="click->list-filter#close"
              type="button"
              aria-label="Close filters">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <% if platforms.any? %>
      <div class="filter-row">
        <span class="filter-row__label">Platform</span>
        <div class="filter-dropdown">
          <button class="filter-dropdown__trigger"
                  data-placeholder="All platforms"
                  data-action="click->list-filter#toggleDropdown"
                  type="button">
            <span class="filter-dropdown__label">All platforms</span>
            <i class="fa-solid fa-chevron-down filter-dropdown__arrow"></i>
          </button>
          <div class="filter-dropdown__menu">
            <% platforms.each do |platform| %>
              <label class="filter-dropdown__option">
                <input type="checkbox"
                       class="filter-checkbox"
                       data-filter-type="platform"
                       data-display-label="<%= short_platform_label(platform) %>"
                       value="<%= platform %>"
                       data-action="change->list-filter#updateDropdownLabel">
                <span><%= short_platform_label(platform) %></span>
              </label>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% if genres.any? %>
      <div class="filter-row">
        <span class="filter-row__label">Genre</span>
        <div class="filter-dropdown">
          <button class="filter-dropdown__trigger"
                  data-placeholder="All genres"
                  data-action="click->list-filter#toggleDropdown"
                  type="button">
            <span class="filter-dropdown__label">All genres</span>
            <i class="fa-solid fa-chevron-down filter-dropdown__arrow"></i>
          </button>
          <div class="filter-dropdown__menu">
            <% genres.each do |genre| %>
              <label class="filter-dropdown__option">
                <input type="checkbox"
                       class="filter-checkbox"
                       data-filter-type="genre"
                       data-display-label="<%= genre %>"
                       value="<%= genre %>"
                       data-action="change->list-filter#updateDropdownLabel">
                <span><%= genre %></span>
              </label>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% if studios.any? %>
      <div class="filter-row">
        <span class="filter-row__label">Studio</span>
        <div class="filter-dropdown">
          <button class="filter-dropdown__trigger"
                  data-placeholder="All studios"
                  data-action="click->list-filter#toggleDropdown"
                  type="button">
            <span class="filter-dropdown__label">All studios</span>
            <i class="fa-solid fa-chevron-down filter-dropdown__arrow"></i>
          </button>
          <div class="filter-dropdown__menu">
            <% studios.each do |studio| %>
              <label class="filter-dropdown__option">
                <input type="checkbox"
                       class="filter-checkbox"
                       data-filter-type="studio"
                       data-display-label="<%= studio %>"
                       value="<%= studio %>"
                       data-action="change->list-filter#updateDropdownLabel">
                <span><%= studio %></span>
              </label>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <div class="filter-row">
      <span class="filter-row__label">Rating</span>
      <div class="filter-slider-row">
        <input type="range"
               class="filter-slider-input"
               data-filter-type="rating"
               min="0" max="10" step="0.5" value="0"
               data-action="input->list-filter#updateSliderLabel">
        <span class="filter-slider-value">—</span>
      </div>
    </div>

    <div class="filter-row">
      <span class="filter-row__label">Year</span>
      <div class="filter-slider-row">
        <input type="range"
               class="filter-slider-input"
               data-filter-type="year"
               min="<%= min_year %>" max="<%= max_year %>" step="1" value="<%= min_year %>"
               data-action="input->list-filter#updateSliderLabel">
        <span class="filter-slider-value">—</span>
      </div>
    </div>

    <div class="list-filter-panel__actions">
      <button class="list-filter-panel__reset"
              data-action="click->list-filter#reset"
              type="button">
        Reset
      </button>
      <button class="list-filter-panel__save"
              data-action="click->list-filter#apply"
              type="button">
        Show results
      </button>
    </div>

  </div>
</div>
