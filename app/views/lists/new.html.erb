<div class="lists-page">
  <%= link_to "< Back", lists_path, class: "list-show__back" %>

  <header>
    <h1 class="lists-title">Create a list</h1>
    <p class="lists-subtitle">Describe what you're looking for</p>
  </header>

  <%= simple_form_for @list do |f| %>
    <%= f.input :name,
          label: false,
          placeholder: "e.g. Best Mario games, cozy rainy day picks…",
          input_html: { class: "form-control" } %>
    <%= f.submit "Find games", class: "btn btn-primary w-100" %>
  <% end %>
</div>

<%= render "shared/bottom_nav", active: :lists %>
