<div class="list-show-page" data-controller="list-edit list-filter">

  <div class="list-show__topbar">
    <%= link_to "‹ Lists", lists_path, class: "list-show__back" %>
  </div>

  <div class="card list-show__header"
       data-controller="share manage-menu"
       data-share-url-value="<%= list_url(@list) %>"
       data-share-title-value="<%= @list.name %>">
    <div class="list-show__header-cover" id="list-header-cover-<%= @list.id %>">
      <%= render "header_cover", list_games: @list_games %>
    </div>
    <div class="list-show__header-info">
      <h1 class="list-show__name"><%= @list.name %></h1>
      <% if current_user == @list.user %>
        <%= form_with model: @list, method: :patch, class: "list-show__name-form" do |f| %>
          <%= f.text_field :name, class: "list-show__name-input", maxlength: 25,
                aria: { label: "List name" } %>
          <button type="submit" class="list-show__name-save" aria-label="Save name">
            <i class="fa-solid fa-check"></i>
          </button>
        <% end %>
      <% end %>
      <p class="list-show__meta" id="list-games-count-<%= @list.id %>"><%= pluralize(@list_games.size, "game") %></p>
      <p class="list-show__meta">by <%= link_to @list.user.gamer_tag, user_path(@list.user), class: "list-show__author-link" %></p>
      <div class="list-show__stats">
          <button class="list-show__share" data-action="click->share#share">
          <i class="fa-solid fa-share-nodes"></i> share
        </button>
        <%= turbo_frame_tag "list-likes-#{@list.id}" do %>
          <%= render "likes_button", list: @list %>
        <% end %>
      </div>
    </div>

    <%# Owner-only "manage" menu — rare admin actions (edit, delete) tucked into
        the header card instead of competing with the content actions. %>
    <% if current_user == @list.user %>
      <div class="list-show__manage">
        <button class="list-show__manage-btn"
                data-action="click->manage-menu#toggle"
                aria-label="Manage list">
          <i class="fa-solid fa-ellipsis"></i>
        </button>
        <div class="list-show__manage-menu" data-manage-menu-target="menu">
          <button class="list-show__manage-item"
                  data-action="click->list-edit#toggle click->manage-menu#close">
            <i class="fa-solid fa-pen"></i> Edit list
          </button>
          <button class="list-show__manage-item list-show__manage-item--danger"
                  data-action="click->confirm-dialog#open click->manage-menu#close">
            <i class="fa-solid fa-trash"></i> Delete list
          </button>
        </div>
      </div>
    <% end %>
  </div>

  <% if current_user == @list.user %>
    <%# Done-editing bar — only visible while editing (toggles edit mode off). %>
    <button class="list-show__done-btn" data-action="click->list-edit#toggle">
      <i class="fa-solid fa-check"></i> Done editing
    </button>

    <%# Find & add games: the primary job on your own list. Discover (browse +
        bulk-add) is the main CTA; the search icon adds a game by title. %>
    <div class="list-show__find">
      <%= link_to build_list_path(@list), class: "list-show__discover-btn" do %>
        <i class="fa-solid fa-compass"></i> Discover games
      <% end %>
      <%= render "shared/search_modal", list_id: @list.id %>
    </div>

    <%# Filter — a floating control, reachable while scrolling the games. %>
    <% if @list_games.any? %>
      <button class="list-show__filter-fab"
              data-action="click->list-filter#toggle"
              data-list-filter-target="toggleBtn"
              aria-label="Filter games">
        <i class="fa-solid fa-sliders"></i>
        <span class="list-show__filter-count" data-list-filter-target="count"></span>
      </button>
      <%= render "lists/filter_panel", list_games: @list_games %>
    <% end %>

    <div class="list-show__delete-zone" data-controller="confirm-dialog">
      <dialog class="confirm-dialog"
              data-confirm-dialog-target="dialog"
              data-action="click->confirm-dialog#backdropClose">
        <div class="confirm-dialog__box">
          <% cover = @list_games.first&.game&.cover_img %>
          <% if cover.present? %>
            <div class="confirm-dialog__cover" <%= lazy_bg(rawg_thumb(cover)) %>></div>
          <% else %>
            <div class="confirm-dialog__cover confirm-dialog__cover--placeholder"></div>
          <% end %>
          <p class="confirm-dialog__message">Do you want to delete <%= @list.name %>?</p>
          <p class="confirm-dialog__hint">This action cannot be undone.</p>
          <div class="confirm-dialog__actions">
            <button type="button"
                    class="confirm-dialog__btn confirm-dialog__btn--cancel"
                    data-action="click->confirm-dialog#close">
              Cancel
            </button>
            <%= form_with url: list_path(@list), method: :delete do |f| %>
              <%= f.submit "Delete", class: "confirm-dialog__btn confirm-dialog__btn--remove" %>
            <% end %>
          </div>
        </div>
      </dialog>
    </div>
  <% end %>

  <div id="list-games-section-<%= @list.id %>">
    <%= render "games_section", list: @list, list_games: @list_games %>
  </div>

</div>

<%= render "shared/navbar" %>
