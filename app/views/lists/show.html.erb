<div class="list-show-page">

  <div class="list-show__topbar">
    <%= link_to "‹ Lists", lists_path, class: "list-show__back" %>

    <% if current_user == @list.user %>
      <%= render "shared/search_modal", list_id: @list.id %>
    <% end %>
  </div>

  <div class="card list-show__header">
    <div class="list-show__title-row">
      <h1 class="list-show__name"><%= @list.name %></h1>
      <% if current_user == @list.user %>
        <%= link_to edit_list_path(@list), class: "list-show__edit", "aria-label": "Edit list" do %>
          <i class="fa-solid fa-pen"></i>
        <% end %>
      <% end %>
    </div>
    <p class="list-show__meta">by <%= @list.user.gamer_tag %> · <%= pluralize(@list_games.size, "game") %></p>
  </div>

  <div class="list-show__actions"
       data-controller="share"
       data-share-url-value="<%= list_url(@list) %>"
       data-share-title-value="<%= @list.name %>">
    <span class="list-show__likes">
      <i class="fa-solid fa-heart"></i> <%= @list.votes_count || 0 %>
    </span>
    <button class="list-show__share" data-action="click->share#share">
      <i class="fa-solid fa-share"></i> Share
    </button>
  </div>

  <% if @list_games.any? %>
    <ol class="list-show__games">
      <% @list_games.each_with_index do |lg, index| %>
        <li class="list-game-row card">
          <span class="list-game-row__rank"><%= index + 1 %></span>
          <%= link_to game_path(lg.game), class: "list-game-row__link" do %>
            <div class="list-game-row__cover" style="background-image: url('<%= lg.game.cover_img %>')"></div>
            <div class="list-game-row__info">
              <span class="list-game-row__title"><%= lg.game.title %></span>
              <span class="list-game-row__genre"><%= lg.game.genre %></span>
            </div>
          <% end %>
          <% if current_user == @list.user %>
            <%= link_to list_game_path(lg),
                  class: "list-game-row__remove",
                  data: { turbo_method: :delete, turbo_confirm: "Remove #{lg.game.title} from this list?" } do %>
              <i class="fa-solid fa-trash"></i>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ol>
  <% end %>

  <% if current_user == @list.user %>
    <div data-controller="confirm-dialog">
      <button class="btn btn-danger w-100 list-show__delete"
              data-action="click->confirm-dialog#open">
        Delete list
      </button>

      <dialog class="confirm-dialog"
              data-confirm-dialog-target="dialog"
              data-action="click->confirm-dialog#backdropClose">
        <div class="confirm-dialog__box">
          <% cover = @list_games.first&.game&.cover_img %>
          <% if cover.present? %>
            <div class="confirm-dialog__cover" style="background-image: url('<%= cover %>')"></div>
          <% else %>
            <div class="confirm-dialog__cover confirm-dialog__cover--placeholder"></div>
          <% end %>
          <p class="confirm-dialog__message">Do you want to delete <%= @list.name %>?</p>
          <p class="confirm-dialog__hint">This action cannot be undone.</p>
          <div class="confirm-dialog__actions">
            <button type="button"
                    class="confirm-dialog__btn confirm-dialog__btn--cancel"
                    data-action="click->confirm-dialog#close">
              Cancel
            </button>
            <%= form_with url: list_path(@list), method: :delete do |f| %>
              <%= f.submit "Delete", class: "confirm-dialog__btn confirm-dialog__btn--remove" %>
            <% end %>
          </div>
        </div>
      </dialog>
    </div>
  <% end %>

</div>

<%= render "shared/navbar" %>
