<div class="lists-page">
  <header class="lists-header">
    <h1 class="lists-title mb-4">
      <%= "#{current_user.gamer_tag}'s lists" %>
    </h1>
    <p class="lists-subtitle mb-2">Wishlists, collections, and everything you've curated.</p>
  </header>

  <% if current_user %>
    <%= link_to "+ Create a new list", new_list_path, class: "btn btn-primary w-100 lists-create-btn" %>
  <% end %>

  <% if @lists.any? %>
    <div class="lists-grid">
      <% @lists.each do |list| %>
        <%= link_to list_path(list), class: "card card-clickable list-card" do %>
          <div class="list-card__covers">
            <% overflow = list.games.size - 3 %>
            <% if overflow > 1 %>
              <% list.games.first(3).each do |game| %>
                <div class="list-card__cover" <%= lazy_bg(rawg_thumb(game.cover_img)) %>></div>
              <% end %>
              <div class="list-card__cover list-card__cover--overflow">+<%= overflow %></div>
            <% else %>
              <% list.games.first(4).each do |game| %>
                <div class="list-card__cover" <%= lazy_bg(rawg_thumb(game.cover_img)) %>></div>
              <% end %>
            <% end %>
          </div>
          <div class="list-card__body">
            <h2 class="list-card__name"><%= list.name %></h2>
            <p class="list-card__author">by you</p>
            <p class="list-card__meta"><%= pluralize(list.games.size, "game") %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="lists-empty">
      <p>You haven't created any lists yet.</p>
    </div>
  <% end %>

</div>

<%= render "shared/navbar", active: :lists %>
