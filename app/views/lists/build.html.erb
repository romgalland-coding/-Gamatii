<div class="lists-page" data-controller="build-filter">
  <%= link_to "‹ Back to list", list_path(@list), class: "list-show__back" %>

  <header class="d-flex justify-content-between align-items-start">
    <div>
      <h1 class="lists-title"><%= @list.name %></h1>
      <p class="lists-subtitle">
        <%= pluralize(@games_in_list.size, "game") %> in this list · browse to add more
      </p>
    </div>
    <div class="d-flex gap-2 align-items-center">
      <button type="button" class="list-show__filter-btn"
              data-action="click->build-filter#toggle"
              data-build-filter-target="toggleBtn">
        <i class="fa-solid fa-sliders"></i> Filter
      </button>
      <%= link_to "Save", list_path(@list), class: "btn btn-primary btn-sm" %>
    </div>
  </header>

  <%= render "lists/build_filter_panel" %>

  <%= turbo_frame_tag "games-grid" do %>
  <% swipe_active = params[:tab] == "swipe" %>
  <div class="d-flex justify-content-center mb-3">
    <div class="view-toggle" role="tablist">
      <button class="view-toggle__btn <%= 'active' unless swipe_active %>" id="grid-tab"
              data-bs-toggle="tab" data-bs-target="#grid-view"
              type="button" role="tab">
        <i class="fa-solid fa-grip"></i> Grid
      </button>
      <button class="view-toggle__btn <%= 'active' if swipe_active %>" id="swipe-tab"
              data-bs-toggle="tab" data-bs-target="#swipe-view"
              type="button" role="tab">
        <i class="fa-solid fa-hand-pointer"></i> Swipe
      </button>
    </div>
  </div>
  <div class="tab-content">
    <div class="tab-pane fade <%= 'show active' unless swipe_active %>" id="grid-view" role="tabpanel">
      <div class="row row-cols-2 g-3" id="games-grid-cards">
        <% @games.each do |game| %>
          <% added = @games_in_list.include?(game["id"]) %>
          <% add_params = {
               origin:     "build",
               rawg_id:    game["id"],
               genres:     params[:genres],
               platforms:  params[:platforms],
               publishers: params[:publishers],
               game_modes: params[:game_modes],
               rating:     params[:rating],
               from:       params[:from],
               to:         params[:to],
               limit:      params[:limit]
             } %>
          <%= render "build_grid_card", game: game, list: @list, add_params: add_params, added: added %>
        <% end %>
      </div>

      <div class="text-center mt-3">
        <%= link_to "See more",
              build_list_path(@list,
                page:       (params[:limit].presence || 20).to_i / 20 + 1,
                limit:      params[:limit],
                tab:        "grid",
                genres:     params[:genres],
                platforms:  params[:platforms],
                publishers: params[:publishers],
                game_modes: params[:game_modes],
                rating:     params[:rating],
                from:       params[:from],
                to:         params[:to]
              ),
              class: "btn btn-outline-primary btn-sm" %>
      </div>
    </div>

    <div class="tab-pane fade <%= 'show active' if swipe_active %>" id="swipe-view" role="tabpanel">
      <div class="swipe-stack" data-controller="swipe">

        <div class="swipe-stack__empty" data-swipe-target="empty" id="swipe-empty-state" style="display:none;">
          <p>You've seen all <%= @games.length %> games!</p>
          <%= link_to "See more",
                build_list_path(@list,
                  page:       (params[:limit].presence || 20).to_i / 20 + 1,
                  limit:      params[:limit],
                  tab:        "swipe",
                  genres:     params[:genres],
                  platforms:  params[:platforms],
                  publishers: params[:publishers],
                  game_modes: params[:game_modes],
                  rating:     params[:rating],
                  from:       params[:from],
                  to:         params[:to]
                ),
                class: "btn btn-outline-primary btn-sm" %>
          <%= link_to "Back to grid", "#grid-view",
                data: { "bs-toggle": "tab", "bs-target": "#grid-view" },
                class: "btn btn-secondary btn-sm" %>
        </div>

        <div class="swipe-stack__cards" data-swipe-target="stack" id="swipe-stack-cards">
          <% @games.reverse_each do |game| %>
            <% added = @games_in_list.include?(game["id"]) %>
            <% add_params = {
                 origin:     "swipe",
                 rawg_id:    game["id"],
                 genres:     params[:genres],
                 platforms:  params[:platforms],
                 publishers: params[:publishers],
                 game_modes: params[:game_modes],
                 rating:     params[:rating],
                 from:       params[:from],
                 to:         params[:to]
               } %>
            <%= render "build_swipe_card", game: game, list: @list, add_params: add_params, added: added %>
          <% end %>
        </div>

        <div class="swipe-stack__actions" data-swipe-target="actions">
          <button class="btn btn-outline-danger swipe-btn" data-action="click->swipe#skip">
            <i class="fa-solid fa-xmark"></i>
          </button>
          <span class="swipe-stack__progress" data-swipe-target="progress"></span>
          <button class="btn btn-outline-success swipe-btn" data-action="click->swipe#add">
            <i class="fa-solid fa-check"></i>
          </button>
        </div>

      </div>
    </div>
  </div>
  <% end %>
</div>

<%= render "shared/navbar", active: :lists %>
