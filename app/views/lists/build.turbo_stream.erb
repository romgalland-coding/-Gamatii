<%# Append new grid cards %>
<% @games.each do |game| %>
  <% added = @games_in_list.include?(game["id"]) %>
  <% grid_add_params = {
       origin:     "build",
       rawg_id:    game["id"],
       genres:     params[:genres],
       platforms:  params[:platforms],
       publishers: params[:publishers],
       game_modes: params[:game_modes],
       rating:     params[:rating],
       from:       params[:from],
       to:         params[:to]
     } %>
  <%= turbo_stream.append "games-grid-cards" do %>
    <%= render "build_grid_card", game: game, list: @list, add_params: grid_add_params, added: added %>
  <% end %>
<% end %>

<%# Append new swipe cards (reverse so the first game ends up on top of the stack) %>
<% @games.reverse_each do |game| %>
  <% added = @games_in_list.include?(game["id"]) %>
  <% swipe_add_params = {
       origin:     "swipe",
       rawg_id:    game["id"],
       genres:     params[:genres],
       platforms:  params[:platforms],
       publishers: params[:publishers],
       game_modes: params[:game_modes],
       rating:     params[:rating],
       from:       params[:from],
       to:         params[:to]
     } %>
  <%= turbo_stream.append "swipe-stack-cards" do %>
    <%= render "build_swipe_card", game: game, list: @list, add_params: swipe_add_params, added: added %>
  <% end %>
<% end %>
